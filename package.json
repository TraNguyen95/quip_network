{
  "name": "gpm-automation-tool",
  "version": "1.0.0",
  "description": "Multi-browser automation tool via GPM Login API for large-scale airdrop",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "create-sample": "node src/utils/createSampleExcel.js",
    "bundle": "esbuild index.js --bundle --platform=node --target=node18 --outfile=dist/bundle.cjs --format=cjs --external:selenium-webdriver --external:puppeteer-core --external:puppeteer-extra --external:puppeteer-extra-plugin-stealth --external:xlsx",
    "build": "npm run bundle && pkg dist/bundle.cjs --targets node18-win-x64 --output dist/automation-tool.exe --config pkg.json"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "pkg": "^5.8.1"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "p-queue": "^8.0.0",
    "puppeteer-core": "^22.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "selenium-webdriver": "^4.20.0",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5"
  },
  "pkg": {
    "assets": [
      "src/**/*",
      "config.json"
    ],
    "outputPath": "dist"
  }
}
